# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=  # Опционально: URL для webhook (например: https://yourdomain.com/webhook). Если не задан, бот работает в режиме polling

# Rutracker
RUTRACKER_LOGIN=your_rutracker_login
RUTRACKER_PASSWORD=your_rutracker_password
RUTRACKER_PROXY=  # Опционально: http://proxy_ip:port (оставьте пустым если не нужен)
RUTRACKER_USER_AGENT=  # Опционально: кастомный User-Agent (оставьте пустым для использования дефолтного)

# Rutracker - параметры поиска и фильтрации
RUTRACKER_MAX_PAGES=2          # Сколько страниц результатов загружать (по ~50 раздач на странице)
RUTRACKER_SEARCH_CACHE_TTL=300 # Время жизни кеша результатов поиска, секунд
RUTRACKER_MIN_SEEDERS=1        # Минимум сидеров для показа раздачи (0 = показывать всё)

# Kinopub (не требует авторизации для поиска)

# Synology NAS
SYNOLOGY_HOST=192.168.1.100
SYNOLOGY_PORT=5000
SYNOLOGY_USERNAME=your_synology_username
SYNOLOGY_PASSWORD=your_synology_password
SYNOLOGY_USE_HTTPS=False

# Download Station папки
DOWNLOAD_STATION_FOLDER_1080=/downloads/1080p
DOWNLOAD_STATION_FOLDER_2160=/downloads/2160p
DOWNLOAD_STATION_FOLDER_SERIAL=/downloads/serials

# Разрешенные пользователи (ID через запятую, например: 123456789,987654321)
ALLOWED_USER_IDS=123456789,987654321

